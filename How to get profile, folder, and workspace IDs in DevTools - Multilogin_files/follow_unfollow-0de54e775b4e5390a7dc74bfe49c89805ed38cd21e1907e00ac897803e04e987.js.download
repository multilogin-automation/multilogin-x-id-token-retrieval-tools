$(document).ready(function(){$(".follow-article-form").on("submit",function(o){o.preventDefault();var t=$(this),l=$(this).find('button[type="submit"]'),n=t.attr("action"),a=l.find("span.followers"),f=l.data("follow-toggle");$.ajax({url:n,data:{currently_following:f},type:"PUT",success:function(o){l.data("follow-toggle",o.currently_following),l.toggleClass("follow",o.currently_following),a.text(o.followers_count)}})}),$(".follow-author-form").on("submit",function(o){o.preventDefault();var t=$(this),l=$(this).find('button[type="submit"]'),n=t.attr("action"),a=$(this).find("span.author-followers"),f=l.data("follow-toggle");$.ajax({url:n,data:{currently_following:f},type:"PUT",success:function(o){l.data("follow-toggle",o.currently_following),l.toggleClass("following",o.currently_following),a.text(o.followers_count+" followers")}})}),$("button.follow-author").click(function(){$(this).hasClass("following")?$(this).find("span.follow-status").text("Follow"):$(this).find("span.follow-status").text("Following")})});